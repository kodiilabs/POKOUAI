    "expo": "^55.0.17",
    "expo-audio": "~55.0.14",
    "expo-build-properties": "^55.0.13",
    "expo-camera": "~55.0.16",
    "expo-dev-client": "~55.0.28",
    "expo-file-system": "~55.0.17",
    "expo-image-picker": "~55.0.19",
    "expo-localization": "^55.0.13",
    "expo-notifications": "~55.0.20",
    "expo-speech": "~55.0.13",
    "expo-sqlite": "~55.0.15",
