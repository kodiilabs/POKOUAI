# .claudeignore — files Claude should not read
#
# Purpose: keep Claude focused on source code that carries reasoning value.
# Excludes lockfiles, generated code, vendored deps, large binaries, and
# build output that burn tokens without informing decisions.
#
# Note: this is a convention. For hard restrictions, also use the
# `permissions` block in .claude/settings.json.

# ---- Lockfiles ----
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Pipfile.lock
Gemfile.lock
Cargo.lock
go.sum
composer.lock

# ---- Build / generated output ----
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
coverage/
*.min.js
*.min.css
*.map

# ---- Vendored / third-party ----
node_modules/
vendor/
third_party/
__pycache__/
.venv/
venv/

# ---- Snapshots / fixtures ----
__snapshots__/
*.snap
fixtures/large/

# ---- Generated API clients / types ----
*.generated.ts
*.generated.js
*.gen.go
generated/

# ---- ML / Data assets ----
*.ckpt
*.pt
*.pth
*.h5
*.onnx
*.safetensors
*.pkl
data/raw/
data/processed/
mlruns/
wandb/

# ---- Binary / media ----
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.mp4
*.mov
*.pdf
*.zip
*.tar.gz

# ---- Logs ----
*.log
logs/

# ---- iOS / Android build artifacts ----
ios/Pods/
ios/build/
DerivedData/
android/.gradle/
android/build/
android/app/build/

# ---- Proprietary workspace config / agent settings ----
.adlc/
.claude/
.skills/
.agents/
.memory/
.workspace-state
.copilot/
.anthropic/
CONSTRAINTS.md
ASSUMPTIONS.md
KNOWLEDGE.md

# ---- Secrets / API keys / credentials ----
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.keystore
secrets/
.aws/
.gcloud/
.azure/
.api-keys
*.token
*.apikey
*.secret
credentials.json
config.json

# ---- Editor / IDE local config ----
.vscode/extensions/
.idea/
.ai-studio/
.history/
